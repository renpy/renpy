
# game/indepth_text.rpy:22
translate portuguese a_label_8d79d234:

    # e "You just clicked to jump to a label."
    e "Você acabou de clicar para saltar para um label."

# game/indepth_text.rpy:28
translate portuguese text_578c4060:

    # e "Sometimes, when showing text, we'll want to change the way some of the text is displayed."
    e "Às vezes, ao mostrar texto, queremos mudar a forma como parte dele é exibida."

# game/indepth_text.rpy:31
translate portuguese text_60750345:

    # e "For example, we might want to have text that is {b}bold{/b}, {i}italic{/i}, {s}struckthrough{/s}, or {u}underlined{/u}."
    e "Por exemplo, talvez queiramos que o texto fique em {b}negrito{/b}, {i}itálico{/i}, {s}tachado{/s} ou {u}sublinhado{/u}."

# game/indepth_text.rpy:33
translate portuguese text_5e1a6ee8:

    # e "That's what text tags are for."
    e "É para isso que servem as tags de texto."

# game/indepth_text.rpy:37
translate portuguese text_38c63ec8:

    # e "Text tags are contained in braces, like the {{b} tag above. When a text tag takes a closing tag, the closing tag begins with a slash, like {{/b} does."
    e "Tags de texto ficam entre chaves, como a tag {{b} acima. Quando uma tag de texto usa uma tag de fechamento, a tag de fechamento começa com uma barra, como {{/b}."

# game/indepth_text.rpy:39
translate portuguese text_1760f9c8:

    # e "We've already seen the b, i, s, and u tags, but there are lot more than those. I'll show you the rest of them."
    e "Já vimos as tags b, i, s e u, mas há muitas outras além dessas. Vou mostrar o resto delas."

# game/indepth_text.rpy:43
translate portuguese text_a620251f:

    # e "The a text tag can {a=https://www.renpy.org}link to a website{/a} or {a=jump:a_label}jump to a label{/a}."
    e "A tag de texto a pode {a=https://www.renpy.org}apontar para um site{/a} ou {a=jump:a_label}saltar para um label{/a}."

# game/indepth_text.rpy:49
translate portuguese after_a_label_d22d5f4a:

    # e "The alpha text tag makes text {alpha=.5}translucent{/alpha}."
    e "A tag de texto alpha faz o texto ficar {alpha=.5}translúcido{/alpha}."

# game/indepth_text.rpy:53
translate portuguese after_a_label_7c2c3cd2:

    # e "The color text tag changes the {color=#0080c0}color{/color} of the text."
    e "A tag de texto color muda a {color=#0080c0}cor{/color} do texto."

# game/indepth_text.rpy:57
translate portuguese after_a_label_3f81fe7b:

    # e "The cps text tag {cps=25}makes text type itself out slowly{/cps}, even if slow text is off."
    e "A tag de texto cps {cps=25}faz o texto ser exibido lentamente{/cps}, mesmo se o texto lento estiver desativado."

# game/indepth_text.rpy:59
translate portuguese after_a_label_b102941f:

    # e "The cps tag can also be relative to the default speed, {cps=*2}doubling{/cps} or {cps=*0.5}halving{/cps} it."
    e "A tag cps também pode ser relativa à velocidade padrão, {cps=*2}dobrando{/cps} ou {cps=*0.5}reduzindo pela metade{/cps}."

# game/indepth_text.rpy:64
translate portuguese after_a_label_22c4339a:

    # e "The font tag changes the font, for example to {font=DejaVuSans-Bold.ttf}DejaVuSans-Bold.ttf{/font}."
    e "A tag font muda a fonte, por exemplo para {font=DejaVuSans-Bold.ttf}DejaVuSans-Bold.ttf{/font}."

# game/indepth_text.rpy:66
translate portuguese after_a_label_d43417d7:

    # e "Sometimes, changing to a bold font looks better than using the {{b} tag."
    e "Às vezes, mudar para uma fonte em negrito fica melhor do que usar a tag {{b}."

# game/indepth_text.rpy:71
translate portuguese after_a_label_f24052f9:

    # e "The k tag changes kerning. It can space the letters of a word {k=-.5}closer together{/k} or {k=.5}farther apart{/k}."
    e "A tag k muda o espaçamento entre letras. Ela pode deixar as letras de uma palavra {k=-.5}mais juntas{/k} ou {k=.5}mais separadas{/k}."

# game/indepth_text.rpy:76
translate portuguese after_a_label_2310b922:

    # e "The size tag changes the size of text. It can make text {size=+10}bigger{/size} or {size=-10}smaller{/size}, or set it to a {size=30}fixed size{/size}."
    e "A tag size muda o tamanho do texto. Ela pode deixar o texto {size=+10}maior{/size} ou {size=-10}menor{/size}, ou defini-lo com um {size=30}tamanho fixo{/size}."

# game/indepth_text.rpy:81
translate portuguese after_a_label_f566abf2:

    # e "The space tag {space=30} adds horizontal space in text.{vspace=30}The vspace tag adds vertical space between lines."
    e "A tag space {space=30} adiciona espaço horizontal no texto.{vspace=30}A tag vspace adiciona espaço vertical entre linhas."

# game/indepth_text.rpy:85
translate portuguese after_a_label_054b9ffa:

    # e "There are a few text tags that only makes sense in dialogue."
    e "Há algumas tags de texto que só fazem sentido em diálogos."

# game/indepth_text.rpy:89
translate portuguese after_a_label_86efc45b:

    # e "The p tag breaks a paragraph,{p}and waits for the player to click."
    e "A tag p quebra um parágrafo,{p}e espera o jogador clicar."

# game/indepth_text.rpy:91
translate portuguese after_a_label_3ece2387:

    # e "If it is given a number as an argument,{p=1.5}it waits that many seconds."
    e "Se receber um número como argumento,{p=1.5}ela espera essa quantidade de segundos."

# game/indepth_text.rpy:95
translate portuguese after_a_label_3881f72d:

    # e "The w tag also waits for a click,{w} except it doesn't break lines,{w=.5} the way p does."
    e "A tag w também espera um clique,{w} exceto que não quebra linhas,{w=.5} como a tag p faz."

# game/indepth_text.rpy:100
translate portuguese after_a_label_e5321e79:

    # eslow "The nw tag causes Ren'Py to continue past slow text,{nw}"
    eslow "A tag nw faz o Ren'Py continuar além do texto lento,{nw}"

# game/indepth_text.rpy:102
translate portuguese after_a_label_1f2697ba:

    # extend " to the next statement."
    extend " para a próxima instrução."

# game/indepth_text.rpy:106
translate portuguese after_a_label_dbfca166:

    # e "To break a line without pausing,\none can write \\n. \\' and \\\" include quotes in the text."
    e "Para quebrar uma linha sem pausar,\npode-se escrever \\n. \\' e \\\" incluem aspas no texto."

# game/indepth_text.rpy:111
translate portuguese after_a_label_ffdf7e76:

    # e "The interpolation feature takes a variable name in square brackets, and inserts it into text."
    e "O recurso de interpolação recebe um nome de variável entre colchetes e o insere no texto."

# game/indepth_text.rpy:117
translate portuguese after_a_label_fc99fcbf:

    # e "For example, this displays the [variable!t]."
    e "Por exemplo, isto mostra o [variable!t]."

# game/indepth_text.rpy:121
translate portuguese after_a_label_c84d9087:

    # e "When the variable name is followed by !q, special characters are quoted. This displays the raw [variable!q!t], including the italics tags."
    e "Quando o nome da variável é seguido por !q, caracteres especiais são escapados. Isto mostra o valor bruto [variable!q!t], incluindo as tags de itálico."

# game/indepth_text.rpy:126
translate portuguese after_a_label_c90f24a8:

    # e "When the variable name is followed by !t, it is translated to [variable!t]. It could be something else in a different language."
    e "Quando o nome da variável é seguido por !t, ele é traduzido para [variable!t]. Em outro idioma, isso pode ser algo diferente."

# game/indepth_text.rpy:129
translate portuguese after_a_label_fb106a95:

    # e "Finally, certain characters are special. [[, {{, and \\ need to be doubled if included in text. The %% character should be doubled if used in dialogue."
    e "Por fim, certos caracteres são especiais. [[, {{ e \\ precisam ser duplicados se forem incluídos no texto. O caractere %% deve ser duplicado se for usado em diálogo."

translate portuguese strings:

    # indepth_text.rpy:115
    old "{i}variable value{/i}"
    new "{i}valor da variável{/i}"

    # indepth_text.rpy:124
    old "translatable text"
    new "texto traduzível"
