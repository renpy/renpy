    old "Yes, I do."
    new "Sim."

    # tutorial_quickstart.rpy:497
    old "No, I don't."
    new "No."

    # tutorial_quickstart.rpy:589
    old "What's your name?"
    new "Qual é o seu nome?"

    # tutorial_quickstart.rpy:591
    old "Guy Shy"
    new "Cara Tímido"

# game/tutorial_quickstart.rpy:449
translate portuguese tutorial_music_a2ffbe9b:

    # e "Let's check out some of the commands that can affect the music channel."
    e "Vamos dar uma olhada em alguns dos comandos que podem afetar o canal music."

# game/tutorial_quickstart.rpy:246
translate portuguese tutorial_images_a5e7eb24:

    # e "The show statement adds a new image on top of all the other images on the screen."
    e "A instrução 'show' adiciona uma nova imagem sobre todas as outras imagens na tela."

# game/tutorial_quickstart.rpy:248
translate portuguese tutorial_images_86e11de2:

    # e "If there is already an image with the same tag, the new image is used to replace the old one."
    e "Se já existir uma imagem com a mesma tag, a nova imagem será usada para substituir a antiga."
