# game/indepth_transitions.rpy:56
translate italian demo_transitions_5bbc72fe:

    # e "Ren'Py ships with a large number of built-in transitions, and also includes classes that let you define your own."
    e "Ren'Py viene fornito con un gran numero di transizioni integrate, e include anche classi che ti permettono di definire le tue."

# game/indepth_transitions.rpy:60
translate italian demo_transitions_menu_3caf78d3:

    # e "What kind of transitions would you like demonstrated?" nointeract
    e "Che tipo di transizioni vorresti vengano dimostrate?" nointeract

# game/indepth_transitions.rpy:95
translate italian demo_simple_transitions_2b4fbae3:

    # e "Okay, I can tell you about simple transitions. We call them simple because they don't take much in the way of configuration."
    e "Ok, posso dirti sulle transizioni semplici. Le chiamiamo semplici perché non richiedono molto nella configurazione."

# game/indepth_transitions.rpy:97
translate italian demo_simple_transitions_4b235ac2:

    # e "But don't let that get you down, since they're the transitions you'll probably use the most in a game."
    e "Ma non lasciare che questo ti scoraggi, dato che sono le transizioni che probabilmente userai di più in un gioco."

# game/indepth_transitions.rpy:103
translate italian demo_simple_transitions_af0431ac:

    # e "The 'dissolve' transition is probably the most useful, blending one scene into another."
    e "La transizione 'dissolve' è probabilmente la più utile, fondendo una scena in un'altra."

# game/indepth_transitions.rpy:109
translate italian demo_simple_transitions_5b9f711f:

    # e "The 'Dissolve' function lets you create your own dissolves, taking a different amount of time."
    e "La funzione 'Dissolve' ti permette di creare le tue dissolvenze, impiegando una quantità diversa di tempo."

# game/indepth_transitions.rpy:116
translate italian demo_simple_transitions_79816523:

    # e "The 'fade' transition fades to black, and then fades back in to the new scene."
    e "La transizione 'fade' sfuma al nero, e poi sfuma di nuovo nella nuova scena."

# game/indepth_transitions.rpy:118
translate italian demo_simple_transitions_141bb95d:

    # e "If you're going to stay at a black screen, you'll probably want to use 'dissolve' rather than 'fade'."
    e "Se intendi restare su uno schermo nero, probabilmente vorrai usare 'dissolve' piuttosto che 'fade'."

# game/indepth_transitions.rpy:123
translate italian demo_simple_transitions_f059f4ae:

    # e "You can use 'Fade' to define your own fades. By changing the timing and color faded to, you can use this for special effects, like flashbulbs."
    e "Puoi usare 'Fade' per definire le tue sfumature. Cambiando il tempo e il colore sfumato, puoi usarlo per effetti speciali, come i lampi."

# game/indepth_transitions.rpy:129
translate italian demo_simple_transitions_e948905b:

    # e "The 'pixellate' transition pixellates out the old scene, switches to the new scene, and then unpixellates that."
    e "La transizione 'pixellate' pixelizza fuori la vecchia scena, passa alla nuova scena, e poi depixelizza quella."

# game/indepth_transitions.rpy:131
translate italian demo_simple_transitions_6a1ae05f:

    # e "It's probably not appropriate for most games, but we think it's kind of neat."
    e "Probabilmente non è appropriata per la maggior parte dei giochi, ma pensiamo che sia piuttosto bella."

# game/indepth_transitions.rpy:134
translate italian demo_simple_transitions_bdfcd85a:

    # e "You can use 'Pixellate' to change the details of the pixellation."
    e "Puoi usare 'Pixellate' per cambiare i dettagli della pixelizzazione."

# game/indepth_transitions.rpy:136
translate italian demo_simple_transitions_432f7224:

    # e "Motions can also be used as transitions."
    e "Le motions possono anche essere usate come transizioni."

# game/indepth_transitions.rpy:138
translate italian demo_simple_transitions_a20cefa7:

    # "..."
    e "..."

# game/indepth_transitions.rpy:140
translate italian demo_simple_transitions_0fd4d656:

    # "......"
    e "......"

# game/indepth_transitions.rpy:146
translate italian demo_simple_transitions_fbf11906:

    # e "Hey! Pay attention."
    e "Ehi! Presta attenzione."

# game/indepth_transitions.rpy:148
translate italian demo_simple_transitions_51c1c5b8:

    # e "I was about to demonstrate 'vpunch'... well, I guess I just did."
    e "Stavo per dimostrare 'vpunch'... beh, credo di aver appena fatto."

# game/indepth_transitions.rpy:154
translate italian demo_simple_transitions_57f19473:

    # e "We can also shake the screen horizontally, with 'hpunch'. These were defined using a 'Move' function."
    e "Possiamo anche scuotere lo schermo orizzontalmente, con 'hpunch'. Questi sono stati definiti usando una funzione 'Move'."

# game/indepth_transitions.rpy:156
translate italian demo_simple_transitions_fce83e12:

    # e "There's also a 'move' transition, which is confusingly enough defined using a 'MoveTransition' function."
    e "C'è anche una transizione 'move', che è definita in modo confusamente sufficiente usando una funzione 'MoveTransition'."

# game/indepth_transitions.rpy:164
translate italian demo_simple_transitions_1050b6a4:

    # e "The 'move' transition finds images that have changed placement, and slides them to their new place. It's an easy way to get motion in your game."
    e "La transizione 'move' trova le immagini che hanno cambiato posizionamento, e le scivola nel loro nuovo posto. È un modo facile per ottenere movimento nel tuo gioco."

# game/indepth_transitions.rpy:168
translate italian demo_simple_transitions_dc776e59:

    # e "That's it for simple transitions."
    e "Questo è tutto per le transizioni semplici."

# game/indepth_transitions.rpy:175
translate italian demo_imagedissolve_transitions_2db67018:

    # e "Perhaps the most flexible kind of transition is ImageDissolve, which lets you use an image to control a dissolve."
    e "Forse il tipo più flessibile di transizione è ImageDissolve, che ti permette di usare un'immagine per controllare una dissolvenza."

# game/indepth_transitions.rpy:177
translate italian demo_imagedissolve_transitions_429f8d03:

    # e "This lets us specify very complex transitions, fairly simply. Let's try some, and then I'll show you how they work."
    e "Questo ci permette di specificare transizioni molto complesse, in modo piuttosto semplice. Proviamone alcune, e poi ti mostrerò come funzionano."

# game/indepth_transitions.rpy:179
translate italian demo_imagedissolve_transitions_1ce501b0:

    # e "There are two ImageDissolve transitions built into Ren'Py."
    e "Ci sono due transizioni ImageDissolve integrate in Ren'Py."

# game/indepth_transitions.rpy:191
translate italian demo_imagedissolve_transitions_ea0413be:

    # e "The 'blinds' transition opens and closes what looks like vertical blinds."
    e "La transizione 'blinds' apre e chiude ciò che sembra come persiane verticali."

# game/indepth_transitions.rpy:201
translate italian demo_imagedissolve_transitions_12e2e0d0:

    # e "The 'squares' transition uses these squares to show things."
    e "La transizione 'squares' usa questi quadrati per mostrare le cose."

# game/indepth_transitions.rpy:203
translate italian demo_imagedissolve_transitions_bbf73d1c:

    # e "I'm not sure why anyone would want to use it, but it was used in some translated games, so we added it."
    e "Non sono sicuro perché qualcuno vorrebbe usarlo, ma è stato usato in alcuni giochi tradotti, quindi l'abbiamo aggiunto."

# game/indepth_transitions.rpy:207
translate italian demo_imagedissolve_transitions_0ab2902d:

    # e "The most interesting transitions aren't in the standard library."
    e "Le transizioni più interessanti non sono nella libreria standard."

# game/indepth_transitions.rpy:209
translate italian demo_imagedissolve_transitions_54aa9bf9:

    # e "These ones require an image the size of the screen, and so we couldn't include them as the size of the screen can change from game to game."
    e "Queste richiedono un'immagine delle dimensioni dello schermo, e quindi non potevamo includerle dato che le dimensioni dello schermo possono cambiare da gioco a gioco."

# game/indepth_transitions.rpy:215
translate italian demo_imagedissolve_transitions_ca316184:

    # e "We can hide things with a 'circleirisin'..."
    e "Possiamo nascondere le cose con un 'circleirisin'..."

# game/indepth_transitions.rpy:221
translate italian demo_imagedissolve_transitions_b8fdf2b6:

    # e "... and show them again with a 'circleirisout'."
    e "... e mostrarle di nuovo con un 'circleirisout'."

# game/indepth_transitions.rpy:227
translate italian demo_imagedissolve_transitions_ee427486:

    # e "The 'circlewipe' transitions changes screens using a circular wipe effect."
    e "Le transizioni 'circlewipe' cambiano gli schermi usando un effetto di pulitura circolare."

# game/indepth_transitions.rpy:233
translate italian demo_imagedissolve_transitions_6f089276:

    # e "The 'dream' transition does this weird wavy dissolve, and does it relatively slowly."
    e "La transizione 'dream' fa questa strana dissolvenza ondeggiante, e la fa relativamente lentamente."

# game/indepth_transitions.rpy:239
translate italian demo_imagedissolve_transitions_c0b9d74d:

    # e "The 'teleport' transition reveals the new scene one line at a time."
    e "La transizione 'teleport' rivela la nuova scena una riga alla volta."

# game/indepth_transitions.rpy:246
translate italian demo_imagedissolve_transitions_72ba11d4:

    # e "This is the background picture used with a circleirisout transition."
    e "Questa è l'immagine di sfondo usata con una transizione circleirisout."

# game/indepth_transitions.rpy:248
translate italian demo_imagedissolve_transitions_fc3b3339:

    # e "When we use an ImageDissolve, white will dissolve in first, followed by progressively darker colors. Let's try it."
    e "Quando usiamo un ImageDissolve, il bianco si dissolverà per primo, seguito da colori progressivamente più scuri. Proviamola."

# game/indepth_transitions.rpy:255
translate italian demo_imagedissolve_transitions_4327dca2:

    # e "If we give ImageDissolve a 'reverse' parameter, black areas will dissolve in first."
    e "Se diamo a ImageDissolve un parametro 'reverse', le aree nere si dissolveranno per prime."

# game/indepth_transitions.rpy:260
translate italian demo_imagedissolve_transitions_3a401ee7:

    # e "This lets circleirisin and circleirisout use the same image."
    e "Questo fa sì che circleirisin e circleirisout usino la stessa immagine."

# game/indepth_transitions.rpy:267
translate italian demo_imagedissolve_transitions_20d9cf6c:

    # e "The teleport transition uses a different image, one that dissolves things in one line at a time."
    e "La transizione teleport usa un'immagine diversa, una che dissolve le cose una riga alla volta."

# game/indepth_transitions.rpy:272
translate italian demo_imagedissolve_transitions_906f7800:

    # e "A dissolve only seems to affect parts of the scene that have changed..."
    e "Una dissolvenza sembra interessare solo le parti della scena che sono cambiate..."

# game/indepth_transitions.rpy:277
translate italian demo_imagedissolve_transitions_4b557a29:

    # e "... which is how we apply the teleport effect to a single character."
    e "... che è come applichiamo l'effetto teleport a un singolo personaggio."

# game/indepth_transitions.rpy:285
translate italian demo_cropmove_transitions_1711a91e:

    # e "The CropMove transition class provides a wide range of transition effects. It's not used very much in practice, though."
    e "La classe di transizione CropMove fornisce una gamma ampia di effetti di transizione. Non è usata molto in pratica, però."

# game/indepth_transitions.rpy:290
translate italian demo_cropmove_transitions_6d82cfd7:

    # e "I'll stand offscreen, so you can see some of its modes. I'll read out the mode name after each transition."
    e "Mi starò fuori schermo, così puoi vedere alcuni dei suoi modi. Leggerò il nome della modalità dopo ogni transizione."

# game/indepth_transitions.rpy:296
translate italian demo_cropmove_transitions_4427c78c:

    # e "We first have wiperight..."
    e "Abbiamo prima wiperight..."

# game/indepth_transitions.rpy:302
translate italian demo_cropmove_transitions_6d1810a1:

    # e "...followed by wipeleft... "
    e "...seguito da wipeleft... "

# game/indepth_transitions.rpy:308
translate italian demo_cropmove_transitions_1dd1c6a1:

    # e "...wipeup..."
    e "...wipeup..."

# game/indepth_transitions.rpy:314
translate italian demo_cropmove_transitions_0ea0fa83:

    # e "...and wipedown."
    e "...e wipedown."

# game/indepth_transitions.rpy:316
translate italian demo_cropmove_transitions_c7cb4c16:

    # e "Next, slides."
    e "Prossimamente, le slide."

# game/indepth_transitions.rpy:322
translate italian demo_cropmove_transitions_462a442f:

    # e "Slideright..."
    e "Slideright..."

# game/indepth_transitions.rpy:328
translate italian demo_cropmove_transitions_f9a2e523:

    # e "...slideleft..."
    e "...slideleft..."

# game/indepth_transitions.rpy:334
translate italian demo_cropmove_transitions_20ce3e9c:

    # e "...slideup..."
    e "...slideup..."

# game/indepth_transitions.rpy:340
translate italian demo_cropmove_transitions_9e00a7a6:

    # e "and slidedown."
    e "e slidedown."

# game/indepth_transitions.rpy:342
translate italian demo_cropmove_transitions_b8a710c1:

    # e "While slide transitions slide in the new scene, slideaways slide out the old scene."
    e "Mentre le transizioni slide scorrono nella nuova scena, le slideaways scorrono fuori dalla vecchia scena."

# game/indepth_transitions.rpy:349
translate italian demo_cropmove_transitions_1efb4cd0:

    # e "Slideawayright..."
    e "Slideawayright..."

# game/indepth_transitions.rpy:355
translate italian demo_cropmove_transitions_bfb5dfd7:

    # e "...slideawayleft..."
    e "...slideawayleft..."

# game/indepth_transitions.rpy:361
translate italian demo_cropmove_transitions_6c1a4a6f:

    # e "...slideawayup..."
    e "...slideawayup..."

# game/indepth_transitions.rpy:367
translate italian demo_cropmove_transitions_1f994a7b:

    # e "and slideawaydown."
    e "e slideawaydown."

# game/indepth_transitions.rpy:369
translate italian demo_cropmove_transitions_025ef723:

    # e "We also have a couple of transitions that use a rectangular iris."
    e "Abbiamo anche una coppia di transizioni che usano un'iride rettangolare."

# game/indepth_transitions.rpy:376
translate italian demo_cropmove_transitions_d00d505e:

    # e "There's irisout..."
    e "C'è irisout..."

# game/indepth_transitions.rpy:383
translate italian demo_cropmove_transitions_016a1e0a:

    # e "... and irisin."
    e "... e irisin."

# game/indepth_transitions.rpy:387
translate italian demo_cropmove_transitions_08d753ed:

    # e "It's enough to make you feel a bit dizzy."
    e "È abbastanza da farti sentire un po' stordito."

# game/indepth_transitions.rpy:393
translate italian demo_pushmove_transitions_003e506d:

    # e "The PushMove transitions use the new scene to push the old one out. Let's take a look."
    e "Le transizioni PushMove usano la nuova scena per spingere fuori quella vecchia. Diamo un'occhiata."

# game/indepth_transitions.rpy:401
translate italian demo_pushmove_transitions_124f375d:

    # e "There's pushright..."
    e "C'è pushright..."

# game/indepth_transitions.rpy:408
translate italian demo_pushmove_transitions_ce380ccb:

    # e "...pushleft..."
    e "...pushleft..."

# game/indepth_transitions.rpy:416
translate italian demo_pushmove_transitions_77629638:

    # e "...pushdown..."
    e "...pushdown..."

# game/indepth_transitions.rpy:424
translate italian demo_pushmove_transitions_b7f33c95:

    # e "... and pushup. And that's it for PushMove-based transitions."
    e "... e pushup. E questo è tutto per le transizioni basate su PushMove."

# game/indepth_transitions.rpy:434
translate italian demo_movetransition_14df0e34:

    # e "The most common MoveTransition is move, which slides around images that have changed position on screen."
    e "La MoveTransition più comune è move, che scorre le immagini che hanno cambiato posizione sullo schermo."

# game/indepth_transitions.rpy:442
translate italian demo_movetransition_84e40422:

    # e "Just like that."
    e "Proprio come quella."

# game/indepth_transitions.rpy:446
translate italian demo_movetransition_098ee9f1:

    # e "There are also moveout and movein transitions."
    e "Ci sono anche transizioni moveout e movein."

# game/indepth_transitions.rpy:448
translate italian demo_movetransition_09748f81:

    # e "The moveout transitions (moveoutleft, moveoutright, moveouttop, and moveoutbottom) slide hidden images off the appropriate side of the screen."
    e "Le transizioni moveout (moveoutleft, moveoutright, moveouttop e moveoutbottom) scorrono le immagini nascoste fuori dal lato appropriato dello schermo."

# game/indepth_transitions.rpy:450
translate italian demo_movetransition_5edf6007:

    # e "The movein transitions (moveinleft, moveinright, moveintop, and moveinbottom) slide in new images."
    e "Le transizioni movein (moveinleft, moveinright, moveintop e moveinbottom) scorrono le nuove immagini dentro."

# game/indepth_transitions.rpy:452
translate italian demo_movetransition_20946d36:

    # e "Let's see them all in action."
    e "Vediamole tutte in azione."

# game/indepth_transitions.rpy:487
translate italian demo_movetransition_569952e3:

    # e "That's it for moveins and moveouts."
    e "Questo è tutto per moveins e moveouts."

# game/indepth_transitions.rpy:489
translate italian demo_movetransition_bbb75540:

    # e "Finally, there are zoomin and zoomout transitions, which show and hide things using a zoom."
    e "Infine, ci sono transizioni zoomin e zoomout, che mostrano e nascondono le cose usando uno zoom."

# game/indepth_transitions.rpy:499
translate italian demo_movetransition_dc5ccd54:

    # e "And that's all there is."
    e "E questo è tutto ciò che c'è."

# game/indepth_transitions.rpy:508
translate italian demo_alphadissolve_51613c02:

    # e "The AlphaDissolve transition lets you use one displayable to combine two others. Click, and I'll show you an example."
    e "La transizione AlphaDissolve ti permette di usare un visualizzabile per combinarne altri due. Clicca, e ti mostrerò un esempio."

# game/indepth_transitions.rpy:518
translate italian demo_alphadissolve_7c08cf8b:

    # e "The AlphaDissolve displayable takes a control displayable, usually an ATL transform."
    e "Il visualizzabile AlphaDissolve prende un visualizzabile di controllo, solitamente una trasformazione ATL."

# game/indepth_transitions.rpy:523
translate italian demo_alphadissolve_068e3e98:

    # e "To be useful, the control displayable should be partially transparent."
    e "Per essere utile, il visualizzabile di controllo dovrebbe essere parzialmente trasparente."

# game/indepth_transitions.rpy:525
translate italian demo_alphadissolve_6a1b6203:

    # e "During an AlphaDissolve, the old screen is used to fill the transparent areas of the image, while the new screen fills the opaque areas."
    e "Durante un AlphaDissolve, la vecchia schermata viene usata per riempire le aree trasparenti dell'immagine, mentre la nuova schermata riempie le aree opache."

# game/indepth_transitions.rpy:529
translate italian demo_alphadissolve_80a728b6:

    # e "For our spotlight example, the old screen is this all-black image."
    e "Per il nostro esempio di riflettore, la vecchia schermata è questa immagine tutta nera."

# game/indepth_transitions.rpy:534
translate italian demo_alphadissolve_ce4380eb:

    # e "The new screen is me just standing here."
    e "La nuova schermata sono io che sto qui in piedi."

# game/indepth_transitions.rpy:542
translate italian demo_alphadissolve_2e95917b:

    # e "By combining them using AlphaDissolve, we can build a complicated effect out of simpler parts."
    e "Combinandole usando AlphaDissolve, possiamo costruire un effetto complesso da parti più semplici."

